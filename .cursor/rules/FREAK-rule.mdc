```c
// Generated per type T:
typedef struct {
    bool has_value;
    int64_t value;       // replace with actual T type
} freak_maybe_int;

#define FREAK_SOME_INT(v) ((freak_maybe_int){ .has_value = true, .value = (v) })
#define FREAK_NOBODY_INT  ((freak_maybe_int){ .has_value = false })
