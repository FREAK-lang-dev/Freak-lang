    MINUS      = "-"
    STAR       = "*"
    SLASH      = "/"
    PERCENT    = "%"
    STAR_STAR  = "**"
    EQ_EQ      = "=="
    BANG_EQ    = "!="
    LT         = "<"
    GT         = ">"
